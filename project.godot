; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Fishing Filosofy"
run/main_scene="uid://6lhw8uwis3tm"
config/features=PackedStringArray("4.5", "C#", "Mobile")
config/icon="res://icon.svg"

[autoload]

AudioManager="*res://Scenes/Audio/AudioManager.tscn"
SceneTransition="*res://Scenes/SceneTransition.tscn"

[display]

window/size/viewport_width=990
window/size/viewport_height=495
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/canvas_textures/default_texture_filter=0

[dotnet]

project/assembly_name="NoNameStudios-MuusaGameProject"

[file_customization]

folder_colors={
"res://Assets/": "orange",
"res://Audio/": "purple",
"res://Design/": "teal",
"res://Scenes/": "blue",
"res://Scripts/": "red"
}

[gui]

theme/custom_font="uid://bjli0c5ipdxuf"

[input]

CastLine={
"deadzone": 0.2,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":0,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":false,"double_click":false,"script":null)
]
}

[input_devices]

sensors/enable_accelerometer=true
pointing/emulate_touch_from_mouse=true

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
